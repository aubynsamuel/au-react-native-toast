{
  "name": "au-react-native-toast",
  "version": "1.0.8",
  "description": "Easily display customizable toast messages in your mobile app. Pure JavaScript/React Native component. No extra dependencies.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native)/)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.jsx?$": "babel-jest",
      "^.+\\.tsx?$": "babel-jest"
    },
    "testEnvironment": "jsdom"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aubynsamuel/au-react-native-toast.git"
  },
  "keywords": [
    "react-native",
    "toast",
    "message",
    "notification",
    "alert",
    "popup",
    "mobile",
    "app",
    "ios",
    "android",
    "component",
    "library",
    "npm",
    "package",
    "javascript",
    "react"
  ],
  "author": "Samuel Aubyn",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/aubynsamuel/au-react-native-toast/issues"
  },
  "homepage": "https://github.com/aubynsamuel/au-react-native-toast#readme",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-syntax-flow": "^7.26.0",
    "@babel/plugin-transform-flow-strip-types": "^7.25.9",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@testing-library/react-native": "^12.9.0",
    "@tsconfig/react-native": "^3.0.5",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.14",
    "@types/react-native": "^0.72.8",
    "@types/react-test-renderer": "^19.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-react-native": "^18.0.0",
    "react-test-renderer": "^19.0.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-native": "^0.76.5"
  }
}
